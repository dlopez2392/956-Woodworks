{
  "redirects": [
    { "source": "/", "has": [{ "type": "host", "value": "www.956woodworks.com" }], "destination": "https://956woodworks.com/", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.956woodworks.com" }], "destination": "https://956woodworks.com/:path*", "permanent": true },
    { "source": "/Gallery.dc.html", "destination": "/gallery.html" },
    { "source": "/Cutting Board Care.dc.html", "destination": "/cutting-board-care.html" },
    { "source": "/Cutting%20Board%20Care.dc.html", "destination": "/cutting-board-care.html" },
    { "source": "/Furniture Care.dc.html", "destination": "/furniture-care.html" },
    { "source": "/Furniture%20Care.dc.html", "destination": "/furniture-care.html" },
    { "source": "/Rolling Pin Care.dc.html", "destination": "/rolling-pin-care.html" },
    { "source": "/Rolling%20Pin%20Care.dc.html", "destination": "/rolling-pin-care.html" },
    { "source": "/956 Woodworks.dc.html", "destination": "/index.html" },
    { "source": "/956%20Woodworks.dc.html", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" }
      ]
    }
  ]
}
